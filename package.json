{
  "name": "project-pilot",
  "displayName": "Project Pilot",
  "description": "Manage projects, SSH hosts, and agent assets for Codex, Claude Code, and Cursor.",
  "version": "4.0.0",
  "publisher": "yczhang1028",
  "icon": "media/icon-512x512.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#3B82F6",
    "theme": "dark"
  },
  "preview": false,
  "qna": "marketplace",
  "keywords": [
    "project",
    "manager",
    "workspace",
    "ssh",
    "remote",
    "folder",
    "organization",
    "agent",
    "skills",
    "mcp",
    "codex",
    "claude",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yczhang1028/project_pilot.git"
  },
  "bugs": {
    "url": "https://github.com/yczhang1028/project_pilot.git/issues"
  },
  "homepage": "https://github.com/yczhang1028/project_pilot.git#readme",
  "license": "MIT",
  "activationEvents": [
    "onStartupFinished",
    "onView:projectPilot.manager",
    "onView:projectPilot.outline",
    "onCommand:projectPilot.showManager",
    "onCommand:projectPilot.openFullscreen",
    "onCommand:projectPilot.toggleDemoMode"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "projectPilot.showManager",
        "title": "Show Manager",
        "category": "Project Pilot"
      },
      {
        "command": "projectPilot.openFullscreen",
        "title": "Open Fullscreen View",
        "category": "Project Pilot",
        "icon": "$(screen-full)"
      },
      {
        "command": "projectPilot.toggleDemoMode",
        "title": "Toggle Screenshot Demo Mode",
        "category": "Project Pilot",
        "icon": "$(preview)"
      },
      {
        "command": "projectPilot.openNewWindow",
        "title": "Open in New Window",
        "category": "Project Pilot",
        "icon": "$(window)"
      },
      {
        "command": "projectPilot.openProject",
        "title": "Open Project",
        "category": "Project Pilot"
      },
      {
        "command": "projectPilot.addLocalProject",
        "title": "Add Local Folder",
        "category": "Project Pilot",
        "icon": "$(folder-opened)"
      },
      {
        "command": "projectPilot.addWorkspaceFile",
        "title": "Add Workspace File",
        "category": "Project Pilot",
        "icon": "$(root-folder)"
      },
      {
        "command": "projectPilot.addSshProject",
        "title": "Add SSH Remote",
        "category": "Project Pilot",
        "icon": "$(vm)"
      },
      {
        "command": "projectPilot.addSshWorkspace",
        "title": "Add SSH Workspace",
        "category": "Project Pilot",
        "icon": "$(vm-connect)"
      },
      {
        "command": "projectPilot.addCurrentFolder",
        "title": "Add Current Folder",
        "category": "Project Pilot",
        "icon": "$(folder)"
      },
      {
        "command": "projectPilot.scanWorkspaceFolders",
        "title": "Scan Workspace Folders",
        "category": "Project Pilot",
        "icon": "$(search)"
      },
      {
        "command": "projectPilot.importConfig",
        "title": "Import Configuration",
        "category": "Project Pilot",
        "icon": "$(cloud-download)"
      },
      {
        "command": "projectPilot.exportConfig",
        "title": "Export Configuration",
        "category": "Project Pilot",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "projectPilot.showConfigPath",
        "title": "Show Configuration Path",
        "category": "Project Pilot",
        "icon": "$(file-directory)"
      },
      {
        "command": "projectPilot.restoreBackup",
        "title": "Restore from Backup",
        "category": "Project Pilot",
        "icon": "$(history)"
      },
      {
        "command": "projectPilot.createBackup",
        "title": "Create Backup",
        "category": "Project Pilot",
        "icon": "$(save)"
      },
      {
        "command": "projectPilot.testSshConnection",
        "title": "Test SSH Connection",
        "category": "Project Pilot",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "projectPilot.openConfigFile",
        "title": "Open Configuration File",
        "category": "Project Pilot",
        "icon": "$(file-code)"
      },
      {
        "command": "projectPilot.refreshOutline",
        "title": "Refresh Outline",
        "category": "Project Pilot",
        "icon": "$(refresh)"
      },
      {
        "command": "projectPilot.toggleOutlineView",
        "title": "Cycle Outline Mode",
        "category": "Project Pilot",
        "icon": "$(list-tree)"
      },
      {
        "command": "projectPilot.syncConfig",
        "title": "Sync Configuration",
        "category": "Project Pilot",
        "icon": "$(sync)"
      },
      {
        "command": "projectPilot.addToFavorites",
        "title": "Add to Favorites",
        "category": "Project Pilot",
        "icon": "$(star-empty)"
      },
      {
        "command": "projectPilot.removeFromFavorites",
        "title": "Remove from Favorites",
        "category": "Project Pilot",
        "icon": "$(star-full)"
      },
      {
        "command": "projectPilot.copyProjectPath",
        "title": "Copy Project Path",
        "category": "Project Pilot",
        "icon": "$(copy)"
      },
      {
        "command": "projectPilot.copyProjectName",
        "title": "Copy Project Name",
        "category": "Project Pilot",
        "icon": "$(symbol-string)"
      },
      {
        "command": "projectPilot.deleteProjectFromOutline",
        "title": "Delete Project",
        "category": "Project Pilot",
        "icon": "$(trash)"
      },
      {
        "command": "projectPilot.moveProjectToGroup",
        "title": "Move Project to Group",
        "category": "Project Pilot",
        "icon": "$(folder-active)"
      },
      {
        "command": "projectPilot.renameOutlineGroup",
        "title": "Rename Group",
        "category": "Project Pilot",
        "icon": "$(edit)"
      },
      {
        "command": "projectPilot.editSshHostFromOutline",
        "title": "Edit SSH Host",
        "category": "Project Pilot",
        "icon": "$(edit)"
      },
      {
        "command": "projectPilot.testSshHostFromOutline",
        "title": "Test SSH Host",
        "category": "Project Pilot",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "projectPilot.migrateSshHostProjects",
        "title": "Migrate Projects to Another Host",
        "category": "Project Pilot",
        "icon": "$(replace-all)"
      },
      {
        "command": "projectPilot.deleteSshHostFromOutline",
        "title": "Delete SSH Host",
        "category": "Project Pilot",
        "icon": "$(trash)"
      },
      {
        "command": "projectPilot.testSshConnectionFromOutline",
        "title": "Test SSH Connection",
        "category": "Project Pilot",
        "icon": "$(debug-disconnect)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "projectPilot",
          "title": "Project Pilot",
          "icon": "media/activity-bar-icon.svg"
        }
      ]
    },
    "views": {
      "projectPilot": [
        {
          "id": "projectPilot.manager",
          "name": "Manager",
          "type": "webview",
          "when": "true"
        },
        {
          "id": "projectPilot.outline",
          "name": "Outline"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "projectPilot.toggleOutlineView",
          "when": "view == projectPilot.outline",
          "group": "navigation@0"
        },
        {
          "command": "projectPilot.refreshOutline",
          "when": "view == projectPilot.outline",
          "group": "navigation@1"
        },
        {
          "command": "projectPilot.openNewWindow",
          "when": "view == projectPilot.manager",
          "group": "navigation@0"
        },
        {
          "command": "projectPilot.openFullscreen",
          "when": "view == projectPilot.manager",
          "group": "navigation@1"
        },
        {
          "command": "projectPilot.addLocalProject",
          "when": "view == projectPilot.outline",
          "group": "navigation@2"
        },
        {
          "command": "projectPilot.addCurrentFolder",
          "when": "view == projectPilot.outline",
          "group": "navigation@3"
        },
        {
          "command": "projectPilot.scanWorkspaceFolders",
          "when": "view == projectPilot.outline",
          "group": "navigation@4"
        },
        {
          "command": "projectPilot.openProject",
          "when": "view == projectPilot.outline",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "when": "view == projectPilot.outline && viewItem =~ /outline-project/",
          "command": "projectPilot.openProject",
          "group": "navigation@1"
        },
        {
          "when": "view == projectPilot.outline && viewItem =~ /outline-project/",
          "command": "projectPilot.copyProjectPath",
          "group": "clipboard@1"
        },
        {
          "when": "view == projectPilot.outline && viewItem =~ /outline-project/",
          "command": "projectPilot.copyProjectName",
          "group": "clipboard@2"
        },
        {
          "when": "view == projectPilot.outline && viewItem =~ /outline-project/",
          "command": "projectPilot.moveProjectToGroup",
          "group": "organization@1"
        },
        {
          "when": "view == projectPilot.outline && viewItem =~ /not-favorited/",
          "command": "projectPilot.addToFavorites",
          "group": "favorites@1"
        },
        {
          "when": "view == projectPilot.outline && viewItem =~ /favorited/",
          "command": "projectPilot.removeFromFavorites",
          "group": "favorites@1"
        },
        {
          "when": "view == projectPilot.outline && viewItem =~ /ssh-project/",
          "command": "projectPilot.testSshConnectionFromOutline",
          "group": "remote@1"
        },
        {
          "when": "view == projectPilot.outline && viewItem =~ /outline-project/",
          "command": "projectPilot.deleteProjectFromOutline",
          "group": "danger@1"
        },
        {
          "when": "view == projectPilot.outline && viewItem =~ /outline-group/ && viewItem =~ /mode:group/",
          "command": "projectPilot.renameOutlineGroup",
          "group": "organization@2"
        },
        {
          "when": "view == projectPilot.outline && viewItem =~ /^outline-host-(used|unused)$/",
          "command": "projectPilot.editSshHostFromOutline",
          "group": "remote@1"
        },
        {
          "when": "view == projectPilot.outline && viewItem =~ /^outline-host-(used|unused)$/",
          "command": "projectPilot.testSshHostFromOutline",
          "group": "remote@2"
        },
        {
          "when": "view == projectPilot.outline && viewItem == outline-host-used",
          "command": "projectPilot.migrateSshHostProjects",
          "group": "organization@1"
        },
        {
          "when": "view == projectPilot.outline && viewItem =~ /^outline-host-(used|unused)$/",
          "command": "projectPilot.deleteSshHostFromOutline",
          "group": "danger@1"
        }
      ],
      "commandPalette": [
        {
          "command": "projectPilot.showManager",
          "when": "true"
        },
        {
          "command": "projectPilot.openFullscreen",
          "when": "true"
        },
        {
          "command": "projectPilot.addCurrentFolder",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "projectPilot.scanWorkspaceFolders",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "projectPilot.addLocalProject",
          "when": "true"
        },
        {
          "command": "projectPilot.addWorkspaceFile",
          "when": "true"
        },
        {
          "command": "projectPilot.addSshProject",
          "when": "true"
        },
        {
          "command": "projectPilot.addSshWorkspace",
          "when": "true"
        },
        {
          "command": "projectPilot.syncConfig",
          "when": "true"
        },
        {
          "command": "projectPilot.testSshConnection",
          "when": "true"
        },
        {
          "command": "projectPilot.toggleOutlineView",
          "when": "true"
        },
        {
          "command": "projectPilot.openNewWindow",
          "when": "false"
        },
        {
          "command": "projectPilot.openProject",
          "when": "false"
        },
        {
          "command": "projectPilot.importConfig",
          "when": "false"
        },
        {
          "command": "projectPilot.exportConfig",
          "when": "false"
        },
        {
          "command": "projectPilot.showConfigPath",
          "when": "false"
        },
        {
          "command": "projectPilot.restoreBackup",
          "when": "false"
        },
        {
          "command": "projectPilot.createBackup",
          "when": "false"
        },
        {
          "command": "projectPilot.openConfigFile",
          "when": "false"
        },
        {
          "command": "projectPilot.refreshOutline",
          "when": "false"
        },
        {
          "command": "projectPilot.addToFavorites",
          "when": "false"
        },
        {
          "command": "projectPilot.removeFromFavorites",
          "when": "false"
        },
        {
          "command": "projectPilot.copyProjectPath",
          "when": "false"
        },
        {
          "command": "projectPilot.copyProjectName",
          "when": "false"
        },
        {
          "command": "projectPilot.deleteProjectFromOutline",
          "when": "false"
        },
        {
          "command": "projectPilot.moveProjectToGroup",
          "when": "false"
        },
        {
          "command": "projectPilot.renameOutlineGroup",
          "when": "false"
        },
        {
          "command": "projectPilot.editSshHostFromOutline",
          "when": "false"
        },
        {
          "command": "projectPilot.testSshHostFromOutline",
          "when": "false"
        },
        {
          "command": "projectPilot.migrateSshHostProjects",
          "when": "false"
        },
        {
          "command": "projectPilot.deleteSshHostFromOutline",
          "when": "false"
        },
        {
          "command": "projectPilot.testSshConnectionFromOutline",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "projectPilot.showManager",
        "key": "ctrl+p ctrl+p",
        "mac": "cmd+p cmd+p"
      },
      {
        "command": "projectPilot.openFullscreen",
        "key": "ctrl+p ctrl+f",
        "mac": "cmd+p cmd+f"
      },
      {
        "command": "projectPilot.addLocalProject",
        "key": "ctrl+p ctrl+l",
        "mac": "cmd+p cmd+l"
      },
      {
        "command": "projectPilot.addCurrentFolder",
        "key": "ctrl+p ctrl+c",
        "mac": "cmd+p cmd+c",
        "when": "workspaceFolderCount > 0"
      }
    ],
    "configuration": {
      "title": "Project Pilot",
      "properties": {
        "projectPilot.defaultView": {
          "type": "string",
          "enum": ["grid", "list", "mini"],
          "default": "mini",
          "enumDescriptions": ["Gallery", "Explorer", "Command"],
          "description": "Default Manager layout: Gallery, Explorer, or Command"
        },
        "projectPilot.autoBackup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically create backups when importing configurations"
        },
        "projectPilot.maxBackups": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum number of backup files to keep"
        },
        "projectPilot.showTypeIcons": {
          "type": "boolean",
          "default": true,
          "description": "Show type icons for projects in tree view"
        },
        "projectPilot.autoDetectTags": {
          "type": "boolean",
          "default": true,
          "description": "Automatically detect and suggest tags for new projects"
        },
        "projectPilot.autoOpenFullscreen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open fullscreen view when VSCode starts. Disable this to use sidebar view only."
        },
        "projectPilot.demoMode": {
          "type": "boolean",
          "default": false,
          "description": "Show fictional read-only project, SSH Host, and Agent Assets data for safe product screenshots. No demo action changes saved projects or scans a machine."
        }
      }
    }
  },
  "scripts": {
    "build": "npm run build:webview && npm run build:ext",
    "build:ext": "tsc -p .",
    "build:webview": "cd webview-ui && npm install && npm run build",
    "test:outline": "npm run build:ext && node test/outlineTreeProvider.test.js && node test/outlineHostActions.test.js",
    "test:sshPath": "npm run build:ext && node test/sshPath.test.js",
    "test:projectPath": "npm run build:ext && node test/projectPath.test.js",
    "test:sshHosts": "npm run build:ext && node test/sshHosts.test.js",
    "test:sshProjectRuntime": "npm run build:ext && node test/sshProjectRuntime.test.js",
    "test:sshHostMessages": "npm run build:ext && node test/sshHostMessages.test.js",
    "test:sshHostManagerModel": "node test/sshHostManagerModel.test.js",
    "test:managerLayout": "node test/managerLayout.test.js",
    "test:modalStack": "node test/modalStackModel.test.js",
    "test:outputChannel": "node test/outputChannel.test.js",
    "test:activationEvents": "node test/activationEvents.test.js",
    "test:performanceReady": "node test/performanceReady.test.js",
    "test:startupPerformance": "npm run build:ext && node test/startupPerformance.test.js",
    "test:resizePerformance": "node test/resizePerformance.test.js",
    "test:demoData": "npm run build:ext && node test/demoData.test.js",
    "test:demoMode": "npm run build:ext && node test/demoMode.test.js",
    "test:mcpParser": "npm run build:ext && node test/mcpParser.test.js",
    "test:agentAssetsMessages": "npm run build:ext && node test/agentAssetsMessages.test.js",
    "test:agentAssetsOpen": "npm run build:ext && node test/agentAssetsOpen.test.js",
    "test:store": "npm run build:ext && node test/store.test.js",
    "test:sshResolve": "npm run build:ext && node test/sshResolve.test.js",
    "watch": "npm run watch:ext",
    "watch:ext": "tsc -w -p .",
    "lint": "echo 'No lint configured'",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^18.19.50",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {}
}
